generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SOCIO
  EMPLEADO
  OBRADOR
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String           @unique
  password        String
  role            Role             @default(EMPLEADO)
  createdShifts   Shift[]
  fundAdditions   FundAddition[]
  cashTrackings   CashTracking[]
  passkeys        Passkey[]
  orders          Order[]
}

model Passkey {
  id                String   @id @default(cuid())
  credentialId      String   @unique
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  publicKey         Bytes
  counter           BigInt   @default(0)
  transports        String?
  createdAt         DateTime @default(now())
}

model Shift {
  id            String    @id @default(cuid())
  date          DateTime  @db.Date
  turno         String
  status        String    @default("ABIERTO")
  createdById   String
  createdBy     User      @relation(fields: [createdById], references: [id])
  efectivo      Decimal   @db.Decimal(10, 2)
  caixa         Decimal   @db.Decimal(10, 2)
  santander     Decimal   @db.Decimal(10, 2)
  efectivoGasto Decimal   @db.Decimal(10, 2)
  fondoInicial  Decimal   @db.Decimal(10, 2)
  fondoFinal    Decimal   @db.Decimal(10, 2)
  expenses      Expense[]
  cashTracking  CashTracking?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Expense {
  id        String  @id @default(cuid())
  shiftId   String
  shift     Shift   @relation(fields: [shiftId], references: [id])
  proveedor String
  importe   Decimal @db.Decimal(10, 2)
}

model FundAddition {
  id          String   @id @default(cuid())
  amount      Decimal  @db.Decimal(10, 2)
  description String?
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
}

enum CashDestination {
  DEPOSITO
  INGRESO_EN_FONDO
  GUARDADO
  FANS
}

model CashTracking {
  id          String           @id @default(cuid())
  shiftId     String           @unique
  shift       Shift            @relation(fields: [shiftId], references: [id])
  destination CashDestination
  createdById String
  createdBy   User             @relation(fields: [createdById], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Order {
  id           String   @id @default(cuid())
  clientName   String
  clientPhone  String
  deliveryDate DateTime
  comment      String?
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
